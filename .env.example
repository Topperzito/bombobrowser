# BomboBrowser — environment variables
#
# These are set automatically in GitHub Actions via repository secrets.
# Copy this file to .env for local development if needed.
#
#   cp .env.example .env

# GitHub token used by the release workflow to create releases and download
# artifacts. In Actions this is always available as secrets.GITHUB_TOKEN.
# For local scripts that call the GitHub API you can set a personal token here.
# GITHUB_TOKEN=ghp_...

# Optional: override the number of parallel build jobs (default: nproc)
# BUILD_JOBS=4

# Optional: override the Firefox source directory (default: firefox-src)
# FIREFOX_SRC=firefox-src
